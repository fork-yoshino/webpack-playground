{
  "name": "webpack-playground",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "build": "webpack --config webpack.prod.js",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "lint:fix": "eslint --fix 'src/**/*.{js,ts}'",
    "stylelint": "stylelint 'src/**/*.{css,scss}'",
    "stylelint:fix": "stylelint --fix 'src/**/*.{css,scss}'",
    "format": "prettier --write 'src/**/*.{js,ts,scss,html}'",
    "fix": "pnpm run format && pnpm run lint:fix && pnpm run stylelint:fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^25.5.0",
    "@webdiscus/pug-loader": "^2.11.1",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dotenv-webpack": "^9.0.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.1",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "pug": "^3.0.4",
    "sass": "^1.85.0",
    "sass-loader": "^16.0.4",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.25.0",
    "webpack": "^5.97.1",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1",
    "webpack-watched-glob-entries-plugin": "^2.2.5"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write",
      "stylelint --fix"
    ],
    "src/**/*.html": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "22.22.2"
  }
}
